generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Parent {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  kids Kid[]

  @@map("parents")
}

model Kid {
  id          String   @id @default(cuid())
  parentId    String   @map("parent_id")
  displayName String   @map("display_name")
  ageRange    AgeRange @map("age_range")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent     Parent      @relation(fields: [parentId], references: [id], onDelete: Cascade)
  characters Character[]

  @@index([parentId])
  @@map("kids")
}

enum AgeRange {
  AGES_8_10
  AGES_11_12
  AGES_13_14

  @@map("age_range")
}

model Character {
  id                     String                  @id @default(cuid())
  kidId                  String                  @map("kid_id")
  name                   String
  vibeDescription        String                  @map("vibe_description")
  visualStyle            VisualStyle             @map("visual_style")
  personalityJson        Json                    @map("personality_json")
  personalityVersion     String                  @map("personality_version")
  statsJson              Json                    @map("stats_json")
  visualUrl              String?                 @map("visual_url")
  visualGenerationStatus VisualGenerationStatus  @default(PENDING) @map("visual_generation_status")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  kid          Kid           @relation(fields: [kidId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]

  @@index([kidId])
  @@index([kidId, createdAt])
  @@map("characters")
}

enum VisualStyle {
  REALISTIC
  CARTOON
  ANIME
  PIXEL

  @@map("visual_style")
}

enum VisualGenerationStatus {
  PENDING
  READY
  FAILED

  @@map("visual_generation_status")
}

model ChatMessage {
  id          String          @id @default(cuid())
  characterId String          @map("character_id")
  role        ChatMessageRole
  content     String
  createdAt   DateTime        @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
  @@map("chat_messages")
}

enum ChatMessageRole {
  USER
  CHARACTER

  @@map("chat_message_role")
}

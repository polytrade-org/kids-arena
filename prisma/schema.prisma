generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Parent {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  kids Kid[]

  @@map("parents")
}

model Kid {
  id           String   @id @default(cuid())
  parentId     String   @map("parent_id")
  displayName  String   @map("display_name")
  ageRange     AgeRange @map("age_range")
  sparkBalance Int      @default(0) @map("spark_balance")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  parent        Parent         @relation(fields: [parentId], references: [id], onDelete: Cascade)
  characters    Character[]
  thumbnailSets ThumbnailSet[]

  @@index([parentId])
  @@map("kids")
}

enum AgeRange {
  AGES_8_10
  AGES_11_12
  AGES_13_14

  @@map("age_range")
}

model Character {
  id                     String                  @id @default(cuid())
  kidId                  String                  @map("kid_id")
  name                   String
  vibeDescription        String                  @map("vibe_description")
  visualStyle            VisualStyle             @map("visual_style")
  personalityJson        Json                    @map("personality_json")
  personalityVersion     String                  @map("personality_version")
  statsJson              Json                    @map("stats_json")
  visualUrl              String?                 @map("visual_url")
  visualGenerationStatus VisualGenerationStatus  @default(PENDING) @map("visual_generation_status")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  kid             Kid           @relation(fields: [kidId], references: [id], onDelete: Cascade)
  chatMessages    ChatMessage[]
  battlesAsA      Battle[]      @relation("BattleCharacterA")
  battlesAsB      Battle[]      @relation("BattleCharacterB")
  battlesWon      Battle[]      @relation("BattleWinner")

  @@index([kidId])
  @@index([kidId, createdAt])
  @@map("characters")
}

enum VisualStyle {
  REALISTIC
  CARTOON
  ANIME
  PIXEL

  @@map("visual_style")
}

enum VisualGenerationStatus {
  PENDING
  READY
  FAILED

  @@map("visual_generation_status")
}

model ChatMessage {
  id          String          @id @default(cuid())
  characterId String          @map("character_id")
  role        ChatMessageRole
  content     String
  createdAt   DateTime        @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
  @@map("chat_messages")
}

enum ChatMessageRole {
  USER
  CHARACTER

  @@map("chat_message_role")
}

model Battle {
  id                 String   @id @default(cuid())
  characterAId       String   @map("character_a_id")
  characterBId       String   @map("character_b_id")
  scenarioId         String   @map("scenario_id")
  winnerId           String   @map("winner_id")
  outcomeNarrative   String   @map("outcome_narrative")
  sparkCoinsAwarded  Int      @map("spark_coins_awarded")
  promptVersion      String   @map("prompt_version")
  createdAt          DateTime @default(now()) @map("created_at")

  characterA Character @relation("BattleCharacterA", fields: [characterAId], references: [id], onDelete: Cascade)
  characterB Character @relation("BattleCharacterB", fields: [characterBId], references: [id], onDelete: Cascade)
  winner     Character @relation("BattleWinner",     fields: [winnerId],     references: [id], onDelete: Cascade)

  @@index([characterAId])
  @@index([characterBId])
  @@index([winnerId])
  @@index([createdAt])
  @@map("battles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Studio module (V1.5) — creator tools for kids making real-world content.
// Same Kid record, same parent dashboard, same Spark economy. See brief §6a.

model ThumbnailSet {
  id               String         @id @default(cuid())
  kidId            String         @map("kid_id")
  videoDescription String         @map("video_description")
  titleText        String         @map("title_text")
  niche            Niche
  stylePreset      ThumbnailStyle @map("style_preset")
  promptVersion    String         @map("prompt_version")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  kid        Kid         @relation(fields: [kidId], references: [id], onDelete: Cascade)
  thumbnails Thumbnail[]

  @@index([kidId, createdAt])
  @@map("thumbnail_sets")
}

model Thumbnail {
  id        String                 @id @default(cuid())
  setId     String                 @map("set_id")
  position  Int
  imageUrl  String?                @map("image_url")
  status    VisualGenerationStatus @default(PENDING)
  selected  Boolean                @default(false)
  createdAt DateTime               @default(now()) @map("created_at")

  set ThumbnailSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([setId])
  @@index([setId, selected])
  @@map("thumbnails")
}

enum Niche {
  CARS
  GAMING
  ANIME
  SPORTS
  GENERAL

  @@map("niche")
}

enum ThumbnailStyle {
  BRIGHT_ENERGETIC
  MYSTERIOUS
  COMEDIC
  PROFESSIONAL

  @@map("thumbnail_style")
}
